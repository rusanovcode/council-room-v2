# Council Room v2 — local environment. Copy to ".env" and fill in.
# ".env" is gitignored; API keys NEVER go into the repo or state.json.

# Build mode: "full" = private local build (subscription CLI + switcher + OAuth).
#             "api"  = public build (API-key providers + local Ollama only).
# Default is "full" when unset.
PROVIDERS_MODE=full

# --- API-key providers (OpenAI-compatible) ---
# A profile references one of these by name (credentialRef). Only set the ones you use.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=

# --- Local models ---
# Ollama needs no key; it must be running at http://localhost:11434
# (start with: ollama serve). Override the base URL only if non-default:
# OLLAMA_BASE_URL=http://localhost:11434/v1
