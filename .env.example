# Council Room v2 — local environment. Copy to ".env" and fill in.
# ".env" is gitignored; API keys NEVER go into the repo or state.json.

# Build mode: "full" = private local build (subscription CLI + switcher + OAuth).
#             "api"  = public build (API-key providers + local Ollama only).
# Default is "full" when unset.
PROVIDERS_MODE=full

# --- API-key network providers ---
# A profile references one of these by name (credentialRef). Only set the ones you use.
# Anthropic is native (/v1/messages, prompt caching); the rest are OpenAI-compatible.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
# OpenRouter key pool: add more keys (each = a separate account = separate free daily
# quota). Council Room rotates agents across all OPENROUTER_API_KEY* keys and fails
# over to the next on a 429 — scales to any count. Free ":free" models cost $0.
# OPENROUTER_API_KEY_2=
# OPENROUTER_API_KEY_3=
MISTRAL_API_KEY=
TOGETHER_API_KEY=

# --- Local models ---
# Ollama needs no key; it must be running at http://localhost:11434
# (start with: ollama serve). Override the base URL only if non-default:
# OLLAMA_BASE_URL=http://localhost:11434/v1
